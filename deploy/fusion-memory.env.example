# Runtime model configuration for Fusion Memory.
# Copy or source the variables you need; do not commit real API keys.

# Local model cache. Keep it outside the repo.
export FUSION_MEMORY_MODEL_CACHE="${FUSION_MEMORY_MODEL_CACHE:-$HOME/.cache/fusion-memory/models}"

# Enable local Qwen embedding and reranker.
export FUSION_MEMORY_EMBEDDING_PROVIDER=qwen
export FUSION_MEMORY_EMBEDDING_MODEL="$FUSION_MEMORY_MODEL_CACHE/Qwen3-Embedding-0.6B"
export FUSION_MEMORY_EMBEDDING_DIMENSION=1024
export FUSION_MEMORY_EMBEDDING_DEVICE="${FUSION_MEMORY_EMBEDDING_DEVICE:-cpu}"
export FUSION_MEMORY_EMBEDDING_BATCH_SIZE=8

export FUSION_MEMORY_RERANKER_PROVIDER=qwen
export FUSION_MEMORY_RERANKER_MODEL="$FUSION_MEMORY_MODEL_CACHE/Qwen3-Reranker-0.6B"
export FUSION_MEMORY_RERANKER_DEVICE="${FUSION_MEMORY_RERANKER_DEVICE:-cpu}"
export FUSION_MEMORY_RERANKER_BATCH_SIZE=8

# Alternative: Aliyun DashScope HTTP APIs. Keep real keys in an ignored local
# env file such as deploy/fusion-memory.local.env.
# export DASHSCOPE_API_KEY=...
# export FUSION_MEMORY_EMBEDDING_PROVIDER=http
# export FUSION_MEMORY_EMBEDDING_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
# export FUSION_MEMORY_EMBEDDING_API_KEY=$DASHSCOPE_API_KEY
# export FUSION_MEMORY_EMBEDDING_MODEL=text-embedding-v4
# export FUSION_MEMORY_EMBEDDING_DIMENSION=1024
# export FUSION_MEMORY_EMBEDDING_ENCODING_FORMAT=float
#
# export FUSION_MEMORY_RERANKER_PROVIDER=http
# export FUSION_MEMORY_RERANKER_ENDPOINT=https://dashscope.aliyuncs.com/compatible-api/v1/reranks
# export FUSION_MEMORY_RERANKER_API_KEY=$DASHSCOPE_API_KEY
# export FUSION_MEMORY_RERANKER_MODEL=qwen3-rerank

# Keep runtime offline once the model directories above are populated.
export HF_HUB_OFFLINE=1
export TRANSFORMERS_OFFLINE=1

# Fill these later when the extractor LLM endpoint is chosen.
# If FUSION_MEMORY_EXTRACTOR_ENDPOINT is unset, Fusion Memory uses the local
# rule-based extractor and does not call an LLM.
# export FUSION_MEMORY_EXTRACTOR_BASE_URL=https://your-provider.example/v1
# Or set the full endpoint directly:
# export FUSION_MEMORY_EXTRACTOR_ENDPOINT=https://your-provider.example/v1/chat/completions
# export FUSION_MEMORY_EXTRACTOR_MODEL=your-extractor-model
# export FUSION_MEMORY_EXTRACTOR_API_KEY=...
# export FUSION_MEMORY_EXTRACTOR_TIMEOUT_SECONDS=30

# Benchmark answer/judge models. FUSION_MEMORY_EVAL_BASE_URL is expanded to
# /chat/completions automatically. Command-line flags can override these.
# export FUSION_MEMORY_EVAL_BASE_URL=https://your-provider.example/v1
# export FUSION_MEMORY_EVAL_ANSWER_MODEL=your-answer-model
# export FUSION_MEMORY_EVAL_JUDGE_MODEL=your-judge-model
# export FUSION_MEMORY_EVAL_MODEL_API_KEY=...
# export FUSION_MEMORY_EVAL_TIMEOUT_SECONDS=60
